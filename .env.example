# ─────────────────────────────────────────────────────────────
# Auction Tracker — Server Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────

# Neon PostgreSQL connection string
# Neon Console → Project → Connection Details
DATABASE_URL=postgresql://username:password@ep-xxx-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# ── Neon Auth (Better Auth) ─────────────────────────────────
# Neon Console → Project → Auth → Configuration → Auth URL
NEON_AUTH_URL=https://ep-xxx-xxx.neonauth.c-6.us-east-1.aws.neon.tech/neondb/auth

# ── AES-256 encryption key for auction site passwords ───────
# Must be exactly 32 characters
# Generate: node -e "console.log(require('crypto').randomBytes(16).toString('hex'))"
ENCRYPTION_KEY=your-32-char-encryption-key-here!!

# Server
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173
